        coalesce(latency_ms, 0)                  as latency_ms,
        request_id,
        date_trunc('hour', to_timestamp(event_ts / 1000))  as event_hour,
        date_trunc('day',  to_timestamp(event_ts / 1000))  as event_date
    from source
    where event_ts is not null
)

select * from cleaned
